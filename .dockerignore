# Build context exclusions for the relay and bracken Dockerfiles.
# Both use the repo root as their build context.

.git
.gitignore
.dockerignore
.github
.venv
venv
env

# Python
__pycache__
*.py[codz]
*.egg-info
.mypy_cache
.pytest_cache
.ruff_cache
.coverage
htmlcov
.tox
.nox
.hypothesis
tests
docs

# Local databases and runtime data
relay.db
relay.db-shm
relay.db-wal
*.sqlite
*.sqlite-shm
*.sqlite-wal

# Bracken build artifacts (rebuilt inside the image)
bracken/node_modules
bracken/dist
bracken/.vite

# Deploy runtime data and secrets
deploy/.env
deploy/relay/data/*
!deploy/relay/data/.gitkeep
deploy/bracken/data

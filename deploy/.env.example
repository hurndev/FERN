# FERN deployment configuration.
#
# Copy to deploy/.env and fill in the values. Both compose files read this file
# via `env_file: ../.env`, so a single copy covers relay + bracken.

# Relay hint(s) baked into the Bracken JS at build time. Comma- or
# space-separated. These pre-fill the "Relay hints" field in the
# create-group modal and act as the bootstrap relays Bracken uses when it
# has no local groups yet. Per spec §13.1 they are starting points only;
# the authoritative relay list lives in each group's genesis (and updates
# via `relay_update` events).
# Examples:
#   VITE_RELAY_URL=wss://relay.example.com
#   VITE_RELAY_URL=wss://relay1.example.com,wss://relay2.example.com
VITE_RELAY_URL=

# Host path for the relay's persistent data (SQLite store + identity keyfile).
# Only used by the relay compose. Relative to deploy/relay/ when set to a
# relative path. Use an absolute path on a backed-up volume for production.
FERN_DATA_DIR=./data

# Path to a trusted-heal trust config JSON file inside the relay container.
# If unset, the relay runs without trusted-witness support (fast heal disabled,
# only rate-limited slow heal works). To enable fast heal, set this to the
# container path where trust-config.json is mounted.
# Example (using the data volume):
#   FERN_TRUST_CONFIG=/data/trust-config.json
FERN_TRUST_CONFIG=
